{
  "mcpServers": {
    "godot": {
      "url": "http://127.0.0.1:3000/mcp"
    },
    "roslyn": {
      "command": "dnx",
      "args": ["RoslynMcp.Server", "-y", "--allow-roll-forward"],
      "env": {}
    },
    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {}
    },
    "mermaid": {
      "command": "npx",
      "args": ["-y", "claude-mermaid"],
      "env": {}
    },
    "nuget": {
      "command": "dnx",
      "args": ["NuGet.Mcp.Server", "-y"],
      "env": {}
    }
  }
}
